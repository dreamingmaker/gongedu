@echo off
:: 한글 깨짐 방지
chcp 65001 >nul

:: 현재 배치파일이 있는 폴더로 이동
cd /d "%~dp0"

echo ==========================================
echo   교육이수 관리시스템 (수동 모드) 시작
echo ==========================================
echo.

:: 1. 백엔드 서버 실행 (새 CMD 창)
:: /k 옵션은 명령어가 끝나거나 에러가 나도 창을 닫지 말라는 뜻입니다.
echo [1/2] 백엔드 서버 실행 중...
start "Backend Server (Port 8180)" cmd /k "cd backend && npm start"

:: 백엔드가 초기화될 시간을 잠깐 줍니다 (2초)
timeout /t 2 >nul

:: 2. 프론트엔드 서버 실행 (새 CMD 창)
echo [2/2] 프론트엔드 서버 실행 중...
start "Frontend Server (Port 2256)" cmd /k "cd .. && cd nginx-1.29.4 && start nginx"

echo.
echo ==========================================
echo   모든 서버 창이 열렸습니다.
echo   창을 닫으면 서버가 종료됩니다.
echo ==========================================
pause